@page
@model InvertirOnlineApp.Pages.FundamentalAnalysisModel

@{
    ViewData["Title"] = "Fundamental Analysis";
}

<link rel="stylesheet"
      href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />

<style>

    body {
        background: #0f172a;
        color: #e2e8f0;
    }

    .card {
        background: #111827;
        border: none;
        border-radius: 16px;
    }

    .card-header {
        background: #1e293b;
        border-bottom: 1px solid #334155;
    }

    .table {
        color: #e2e8f0;
        font-size: 14px;
        white-space: nowrap;
    }

    table.dataTable thead {
        background: #1e293b;
    }

    table.dataTable thead th {
        color: white !important;
        border-bottom: 1px solid #334155 !important;
    }

    table.dataTable tbody tr {
        background: #111827;
    }

    table.dataTable tbody tr:hover {
        background: #1e293b !important;
    }

    td, th {
        vertical-align: middle !important;
    }

    .metric-good {
        background: rgba(34,197,94,0.18) !important;
        color: #86efac !important;
        font-weight: 600;
    }

    .metric-warning {
        background: rgba(250,204,21,0.18) !important;
        color: #fde68a !important;
        font-weight: 600;
    }

    .metric-bad {
        background: rgba(239,68,68,0.18) !important;
        color: #fca5a5 !important;
        font-weight: 600;
    }

    .score-badge {
        font-size: 14px;
        padding: 8px 12px;
        border-radius: 999px;
        font-weight: bold;
    }

    .score-excellent {
        background: #22c55e;
        color: white;
    }

    .score-good {
        background: #eab308;
        color: black;
    }

    .score-bad {
        background: #ef4444;
        color: white;
    }

    .empresa-cell {
        min-width: 220px;
    }

    .symbol-cell {
        font-size: 15px;
        font-weight: bold;
        color: #60a5fa;
    }

</style>

<div class="container-fluid mt-4">

    <div class="card shadow-lg">

        <div class="card-header d-flex justify-content-between align-items-center">

            <div>
                <h2 class="mb-0">
                    📈 Fundamental Analysis Screener
                </h2>

                <small class="text-secondary">
                    Value + Growth + Quality Metrics
                </small>
            </div>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table id="tablaFundamental"
                       class="table table-hover align-middle">

                    <thead>
                        <tr>

                            <th>Symbol</th>
                            <th>Empresa</th>

                            <th>P/E</th>
                            <th>P/B</th>

                            <th>ROE</th>
                            <th>Margin</th>

                            <th>Rev Growth</th>
                            <th>EPS Growth</th>

                            <th>D/E</th>

                            <th>Dividend</th>

                            <th>Score</th>

                            <th>Recommendation</th>

                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var e in Model.Empresas)
                        {
                            <tr>

                                <td class="symbol-cell">
                                    @e.Symbol
                                </td>

                                <td class="empresa-cell">

                                    <div class="fw-bold">
                                        @e.CompanyName
                                    </div>

                                    <small class="text-secondary">
                                        @e.Sector
                                    </small>

                                </td>

                                <td class="@Model.GetColorClassLow(e.PERatio, 20, 30)">
                                    @e.PERatio?.ToString("0.0")
                                </td>

                                <td class="@Model.GetColorClassLow(e.PriceToBook, 3, 6)">
                                    @e.PriceToBook?.ToString("0.0")
                                </td>

                                <td class="@Model.GetColorClassGood(e.ROE, 15, 8)">
                                    @e.ROE?.ToString("0.0")%
                                </td>

                                <td class="@Model.GetColorClassGood(e.NetMargin, 15, 8)">
                                    @e.NetMargin?.ToString("0.0")%
                                </td>

                                <td class="@Model.GetColorClassGood(e.RevenueGrowth, 10, 5)">
                                    @e.RevenueGrowth?.ToString("0.0")%
                                </td>

                                <td class="@Model.GetColorClassGood(e.EPSGrowth, 10, 5)">
                                    @e.EPSGrowth?.ToString("0.0")%
                                </td>

                                <td class="@Model.GetColorClassLow(e.DebtToEquity, 1, 2)">
                                    @e.DebtToEquity?.ToString("0.0")
                                </td>

                                <td class="@Model.GetColorClassGood(e.DividendYield, 2, 1)">
                                    @e.DividendYield?.ToString("0.0")%
                                </td>

                                <td>

                                    <span class="score-badge @Model.GetScoreClass(e.FundamentalScore)">

                                        @e.FundamentalScore

                                    </span>

                                </td>

                                <td>

                                    <strong>
                                        @e.Recommendation
                                    </strong>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>

        $(document).ready(function () {

            $('#tablaFundamental').DataTable({

                pageLength: 25,

                order: [[10, 'desc']],

                scrollX: true,

                autoWidth: false,

                responsive: true,

                language: {

                    search: "_INPUT_",
                    searchPlaceholder: "Buscar empresa..."

                }

            });

        });

    </script>
}